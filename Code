            "App Crash": ["frozen", "crash", "glitch", "error", "declined", "white screen"]
        }
    }
};

// 2. TEXT INTERPRETATION ENGINE (Extracts and Traces Issues)
function interpretFeedback(customerName, orderId, rawText) {
    const textLower = rawText.toLowerCase();
    let detectedCategory = "Others";
    let detectedIssue = "Not detected";
    let assignedDept = "General Support";
    let status = "Not contact yet"; // Matches ...41.png initial state

    // Scan through our hierarchical layout
    for (const [category, data] of Object.entries(keywordTaxonomy)) {
        for (const [issue, keywords] of Object.entries(data.issues)) {
            // Pattern recognition check via substring parsing
            const matchFound = keywords.some(keyword => textLower.includes(keyword));
            
            if (matchFound) {
                detectedCategory = category;
                detectedIssue = issue;
                assignedDept = data.department;
                status = "In process"; 
                break;
            }
        }
        if (detectedCategory !== "Others") break;
    }

    return {
        id: Math.floor(100000 + Math.random() * 900000), // Unique Order/Ticket ID
        timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
        customer: customerName,
        orderId: orderId,
        feedbackText: rawText,
        category: detectedCategory,
        issue: detectedIssue,
        accountability: assignedDept,
        status: status
    };
}

// 3. INTERNAL COLLABORATION STATE MGR (Chat View Specification)
class MeowieChatManager {
    constructor() {
        this.channels = {
            "Logistics Team": [
                { sender: "Admin", message: "Hey! We just got a new complaint (ID: #482731) about a late delivery for Daniel Nguyen. Can you check the status?", time: "18:38" },
                { sender: "Logistics Manager", message: "Checking now. It looks like it's stuck at the regional hub due to the weather.", time: "18:39" },
                { sender: "Admin", message: "Got it. The customer is quite upset. Can we prioritize this once the weather clears?", time: "18:39" },
                { sender: "Logistics Manager", message: "I'll inform the staff and reach out asap", time: "18:40" } // Exact string match to ...00.png
            ]
        };
    }

    getChannelMessages(department) {
        return this.channels[department] || [];
    }

    sendMessage(department, sender, text) {
        if (!this.channels[department]) this.channels[department] = [];
        this.channels[department].push({
            sender: sender,
            message: text,
            time: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
        });
    }
}

// 4. METRICS & COUNTERS COMPILER (Dashboard Analytics Calculation)
function compileDashboardMetrics(allTickets) {
    const totalCount = allTickets.length;
    if (totalCount === 0) return { newFeedback: 0, resolutionRate: "0%", csat: "😊 Normal" };

    const resolved = allTickets.filter(t => t.status === "Dissolved").length;
    const resolutionRate = ((resolved / totalCount) * 100).toFixed(1);

    // Dynamic CSAT assignment based on resolved percentages
    let csatBadge = "😊 Normal";
    if (resolutionRate > 90) csatBadge = "😊 High Customer Satisfaction";

    return {
        newFeedback: allTickets.filter(t => t.status === "Not contact yet").length,
        avgResponseTime: "1.8m", // Standardized performance variable
        resolutionRate: `${resolutionRate}%`,
        csat: csatBadge
    };
}

