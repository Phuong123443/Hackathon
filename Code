    "Shipping": {
        department: "Logistics Team",
        issues: {
            "Late Delivery": ["delay", "still hasn't arrived", "overdue", "stuck", "waiting", "slow"],
            "Package arrived damaged": ["broken box", "crushed", "smashed", "damaged", "wet"]
        }
    },
    "Quality": {
