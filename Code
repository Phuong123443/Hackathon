        issues: {
            "Defective Product": ["faulty", "snapped", "dead", "broken", "ripped", "tear"],
            "Incorrect Item": ["not what I ordered", "mistake", "wrong size", "wrong color"]
        }
    },
    "Refund": {
        department: "Finance Team",
        issues: {
            "Amount Error": ["short", "missing dollars", "wrong math", "partial", "charged twice"]
        }
    },
    "Technical": {
